{
    "name": "thanonroom/thanonroom20042569",
    "description": "Modern PHP 8.x app with Telegram and Google Calendar integrations",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "nutgram/nutgram": "^4.0",
        "spatie/browsershot": "^5.0",
        "openspout/openspout": "^4.24",
        "php-flasher/flasher": "^1.15",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "filp/whoops": "^2.15"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
